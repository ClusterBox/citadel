# syntax=docker/dockerfile:1
# Build stage
FROM golang:1.25-alpine AS build
WORKDIR /src
RUN apk add --no-cache git
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/citadel-logs ./cmd/citadel-logs

# Runtime stage
FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /
COPY --from=build /out/citadel-logs /citadel-logs
EXPOSE 5500
VOLUME ["/data"]
USER nonroot:nonroot
ENTRYPOINT ["/citadel-logs"]
